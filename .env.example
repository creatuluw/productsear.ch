# PostgreSQL (Railway te9_dev schema)
DATABASE_URL="postgresql://postgres:REPLACE_ME@host:port/railway"

# RAG chat provider — DeepSeek (OpenAI-compatible). Set OPENAI_API_KEY + CHAT_BASE_URL
# instead to use OpenAI/OpenRouter.
DEEPSEEK_API_KEY="sk-REPLACE_ME"
CHAT_MODEL="deepseek-chat"
CHAT_BASE_URL="https://api.deepseek.com/v1"

# Embeddings — local model via @huggingface/transformers (no key needed).
# To use OpenAI instead: set OPENAI_API_KEY and swap embeddings.ts back to the OpenAI client.
EMBEDDING_MODEL="Xenova/all-MiniLM-L6-v2"
EMBEDDING_DIMENSIONS="384"
# Voyage AI — for the voyage-4-large embeddings + rerank-2.5 upgrade
VOYAGE_API_KEY="pa-REPLACE_ME"
RERANK_MODEL="rerank-2.5-lite"

DB_SCHEMA="te9_dev"
